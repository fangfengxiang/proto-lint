{
    "name": "php-proto-lint/php-proto-lint",
    "description": "Schema-First PHP protocol governance and consistency lint engine for .proto contracts",
    "type": "project",
    "license": "Apache-2.0",
    "keywords": [
        "proto",
        "protobuf",
        "lint",
        "static-analysis",
        "contract",
        "schema-first",
        "code-quality",
        "cli"
    ],
    "authors": [
        {
            "name": "php-proto-lint",
            "homepage": "https://github.com/fangfengxiang/php-proto-lint"
        }
    ],
    "support": {
        "issues": "https://github.com/fangfengxiang/php-proto-lint/issues",
        "source": "https://github.com/fangfengxiang/php-proto-lint",
        "docs": "https://github.com/fangfengxiang/php-proto-lint#readme"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "nikic/php-parser": "^5.0",
        "google/protobuf": "^5.29",
        "symfony/console": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "PhpProtoLint\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpProtoLint\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/php-proto-lint"
    ],
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite Unit",
        "test:integration": "phpunit --testsuite Integration",
        "test:coverage": "phpunit --coverage-clover coverage.xml",
        "cs:check": "php-cs-fixer check --diff --allow-risky=yes",
        "cs:fix": "php-cs-fixer fix --allow-risky=yes",
        "stan": "phpstan analyse",
        "check-all": [
            "@cs:check",
            "@stan",
            "@test"
        ]
    },
    "scripts-descriptions": {
        "test": "Run the full test suite",
        "test:unit": "Run unit tests only",
        "test:integration": "Run integration tests only",
        "test:coverage": "Run tests with code coverage report",
        "cs:check": "Check code style compliance (PER 2.0)",
        "cs:fix": "Auto-fix code style violations",
        "stan": "Run PHPStan static analysis (level 5)",
        "check-all": "Run all checks: cs:check + stan + test"
    },
    "extra": {
        "branch-alias": {
            "dev-develop": "0.x-dev"
        }
    }
}
